@model List<MechanicService.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">Add New Vehicle</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No vehicles found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>License Plate</th>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Year</th>
                        <th>Available</th>
                        <th>Service Types</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vehicle in Model)
                    {
                        <tr>
                            <td>@vehicle.LicensePlate</td>
                            <td>@vehicle.Make</td>
                            <td>@vehicle.Model</td>
                            <td>@vehicle.YearOfManufacture</td>
                            <td>
                                @if (vehicle.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">In Service</span>
                                }
                            </td>
                            <td>
                                @if (vehicle.ServiceTypes.Count > 0)
                                {
                                    @foreach (var st in vehicle.ServiceTypes.Take(2))
                                    {
                                        <span class="badge bg-info">@st.Name</span>
                                    }
                                    @if (vehicle.ServiceTypes.Count > 2)
                                    {
                                        <span class="badge bg-secondary">+@(vehicle.ServiceTypes.Count - 2) more</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@vehicle.Id" class="btn btn-info btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-id="@vehicle.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@vehicle.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
