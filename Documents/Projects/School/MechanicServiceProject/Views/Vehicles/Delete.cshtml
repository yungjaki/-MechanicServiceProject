@model MechanicService.Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <hr />

            <div class="alert alert-warning">
                <p>Are you sure you want to delete this vehicle?</p>
            </div>

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">License Plate</dt>
                        <dd class="col-sm-9">@Model.LicensePlate</dd>

                        <dt class="col-sm-3">Make</dt>
                        <dd class="col-sm-9">@Model.Make</dd>

                        <dt class="col-sm-3">Model</dt>
                        <dd class="col-sm-9">@Model.Model</dd>

                        <dt class="col-sm-3">Year</dt>
                        <dd class="col-sm-9">@Model.YearOfManufacture</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsAvailable)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">In Service</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Service Types</dt>
                        <dd class="col-sm-9">
                            @if (Model.ServiceTypes.Count > 0)
                            {
                                @foreach (var st in Model.ServiceTypes)
                                {
                                    <span class="badge bg-info">@st.Name</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">None</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>
