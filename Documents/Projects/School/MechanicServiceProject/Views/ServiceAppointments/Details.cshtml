@model MechanicService.Models.ServiceAppointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Customer</dt>
                        <dd class="col-sm-9">@Model.Customer?.FullName</dd>

                        <dt class="col-sm-3">Customer Email</dt>
                        <dd class="col-sm-9">@Model.Customer?.Email</dd>

                        <dt class="col-sm-3">Customer Phone</dt>
                        <dd class="col-sm-9">@Model.Customer?.Phone</dd>

                        <dt class="col-sm-3">Vehicle</dt>
                        <dd class="col-sm-9">@Model.Vehicle?.LicensePlate</dd>

                        <dt class="col-sm-3">Make / Model</dt>
                        <dd class="col-sm-9">@Model.Vehicle?.Make @Model.Vehicle?.Model</dd>

                        <dt class="col-sm-3">Year</dt>
                        <dd class="col-sm-9">@Model.Vehicle?.YearOfManufacture</dd>

                        <dt class="col-sm-3">Appointment Date</dt>
                        <dd class="col-sm-9">@Model.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-3">Completion Date</dt>
                        <dd class="col-sm-9">@Model.CompletionDate.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-3">Total Price</dt>
                        <dd class="col-sm-9"><strong>$@Model.TotalPrice.ToString("0.00")</strong></dd>
                    </dl>
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>
