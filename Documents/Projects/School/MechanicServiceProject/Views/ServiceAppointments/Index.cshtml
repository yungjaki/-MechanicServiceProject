@model List<MechanicService.Models.ServiceAppointment>

@{
    ViewData["Title"] = "Service Appointments";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1>@ViewData["Title"]</h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">New Appointment</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No appointments found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Appointment Date</th>
                        <th>Completion Date</th>
                        <th>Total Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model)
                    {
                        <tr>
                            <td>@appointment.Customer?.FullName</td>
                            <td>@appointment.Vehicle?.LicensePlate</td>
                            <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</td>
                            <td>@appointment.CompletionDate.ToString("yyyy-MM-dd")</td>
                            <td>$@appointment.TotalPrice.ToString("0.00")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-info btn-sm">Details</a>
                                <a asp-action="Edit" asp-route-id="@appointment.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
