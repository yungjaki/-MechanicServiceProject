@model MechanicService.Models.ServiceAppointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <hr />

            <div class="alert alert-warning">
                <p>Are you sure you want to delete this appointment?</p>
            </div>

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Customer</dt>
                        <dd class="col-sm-9">@Model.Customer?.FullName</dd>

                        <dt class="col-sm-3">Vehicle</dt>
                        <dd class="col-sm-9">@Model.Vehicle?.LicensePlate</dd>

                        <dt class="col-sm-3">Appointment Date</dt>
                        <dd class="col-sm-9">@Model.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-3">Completion Date</dt>
                        <dd class="col-sm-9">@Model.CompletionDate.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-3">Total Price</dt>
                        <dd class="col-sm-9">$@Model.TotalPrice.ToString("0.00")</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="mt-3">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>
