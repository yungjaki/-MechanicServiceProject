@model MechanicService.Models.Vehicle

@{
    ViewData["Title"] = "Vehicle Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>
            <hr />

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">License Plate</dt>
                        <dd class="col-sm-9">@Model.LicensePlate</dd>

                        <dt class="col-sm-3">Make</dt>
                        <dd class="col-sm-9">@Model.Make</dd>

                        <dt class="col-sm-3">Model</dt>
                        <dd class="col-sm-9">@Model.Model</dd>

                        <dt class="col-sm-3">Year</dt>
                        <dd class="col-sm-9">@Model.YearOfManufacture</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsAvailable)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">In Service</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Service Types</dt>
                        <dd class="col-sm-9">
                            @if (Model.ServiceTypes.Count > 0)
                            {
                                @foreach (var st in Model.ServiceTypes)
                                {
                                    <div class="badge bg-info">@st.Name</div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">None</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="mt-4">
                <h4>Service Appointments</h4>
                @if (Model.ServiceAppointments.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Customer</th>
                                    <th>Appointment Date</th>
                                    <th>Completion Date</th>
                                    <th>Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appointment in Model.ServiceAppointments)
                                {
                                    <tr>
                                        <td>@appointment.Customer?.FullName</td>
                                        <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</td>
                                        <td>@appointment.CompletionDate.ToString("yyyy-MM-dd")</td>
                                        <td>$@appointment.TotalPrice.ToString("0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No appointments yet.</p>
                }
            </div>

            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>
